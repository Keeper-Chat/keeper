{
  "name": "thekeeper-client",
  "version": "0.1.2",
  "description": "Terminal client for TheKeeper encrypted chat",
  "type": "module",
  "bin": {
    "thekeeper": "./dist/index.js",
    "keeper": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "thekeeper",
    "cli",
    "tui",
    "chat",
    "openpgp",
    "encrypted"
  ],
  "homepage": "https://github.com/Keeper-Chat/keeper/tree/main/client",
  "bugs": {
    "url": "https://github.com/Keeper-Chat/keeper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Keeper-Chat/keeper.git",
    "directory": "client"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "preferGlobal": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run",
    "start": "node dist/index.js",
    "test": "node --test --import tsx"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "ink": "^5.2.1",
    "openpgp": "^6.1.0",
    "react": "^18.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
